{
  "agents": {
    "defaults": {
      "workspace": "/sandbox",
      "model": "claude-sonnet-4-6",
      "provider": "cliproxy",
      "maxTokens": 4096,
      "contextWindowTokens": 262144,
      "temperature": 0.3,
      "maxToolIterations": 75,
      "reasoningEffort": null
    }
  },
  "channels": {
    "sendProgress": true,
    "sendToolHints": true
  },
  "providers": {
    "cliproxy": {
      "apiKey": "protoresearcher-internal",
      "apiBase": "http://127.0.0.1:8317/v1",
      "extraHeaders": null
    },
    "vllm": {
      "apiKey": "none",
      "apiBase": "http://host.docker.internal:8000/v1",
      "extraHeaders": null
    }
  },
  "gateway": {
    "host": "0.0.0.0",
    "port": 18790,
    "heartbeat": {
      "enabled": false,
      "intervalS": 1800
    }
  },
  "tools": {
    "web": {
      "proxy": null,
      "search": {
        "provider": "duckduckgo",
        "apiKey": "",
        "baseUrl": "",
        "maxResults": 10
      }
    },
    "exec": {
      "timeout": 60,
      "pathAppend": ""
    },
    "restrictToWorkspace": true,
    "mcpServers": {}
  }
}
