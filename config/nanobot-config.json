{
  "agents": {
    "defaults": {
      "workspace": "/sandbox",
      "model": "openai/local",
      "provider": "vllm",
      "maxTokens": 4096,
      "contextWindowTokens": 131072,
      "temperature": 0.3,
      "maxToolIterations": 75,
      "reasoningEffort": null
    }
  },
  "channels": {
    "sendProgress": true,
    "sendToolHints": true
  },
  "providers": {
    "gateway": {
      "apiKey": "${OPENAI_API_KEY}",
      "apiBase": "http://gateway:4000/v1",
      "extraHeaders": null
    },
    "vllm": {
      "apiKey": "none",
      "apiBase": "http://host.docker.internal:8000/v1",
      "extraHeaders": null
    }
  },
  "gateway": {
    "host": "0.0.0.0",
    "port": 18790,
    "heartbeat": {
      "enabled": false,
      "intervalS": 1800
    }
  },
  "tools": {
    "web": {
      "proxy": null,
      "search": {
        "provider": "duckduckgo",
        "apiKey": "",
        "baseUrl": "",
        "maxResults": 10
      }
    },
    "exec": {
      "timeout": 60,
      "pathAppend": ""
    },
    "restrictToWorkspace": true,
    "mcpServers": {
      "rabbit-hole": {
        "type": "streamableHttp",
        "url": "http://host.docker.internal:3398/mcp",
        "headers": {
          "Authorization": "Bearer ${MCP_AUTH_TOKEN}"
        },
        "toolTimeout": 60,
        "enabledTools": ["*"]
      }
    }
  }
}
